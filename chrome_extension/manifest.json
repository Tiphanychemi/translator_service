{
  "manifest_version": 3,
  "name": "Darija Translator",
  "version": "1.0",
  "description": "Translate selected text to Moroccan Darija using your REST API.",
  "permissions": ["contextMenus", "storage", "tabs"],
  "host_permissions": ["http://localhost:8080/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Darija Translator"
  }
}